{
  "name": "foil",
  "module": "index.ts",
  "type": "module",
  "scripts": {
    "dev": "bun --watch run src/entrypoints/cli/index.tsx",
    "build": "bun build src/entrypoints/cli/index.tsx --outdir dist --target bun",
    "db:generate": "bunx drizzle-kit generate --dialect sqlite --schema ./src/db/schema.ts",
    "db:migrate": "bun run migrate.ts",
    "db:push": "bunx drizzle-kit push --dialect sqlite",
    "lint": "bunx eslint src",
    "format": "bunx prettier --write src"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.1.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@ai-sdk/mcp": "^1.0.30",
    "@ai-sdk/openai": "^3.0.50",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ai": "^6.0.136",
    "drizzle-orm": "^0.45.2",
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "marked": "15",
    "marked-terminal": "^7.3.0",
    "react": "^19.2.4",
    "react-devtools-core": "^7.0.1",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver-types": "^3.17.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  }
}
